{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "html-sitemap/html-sitemap-block",
  "version": "2.0",
  "title": "HTML Sitemap",
  "category": "widgets",
  "icon": "editor-ul",
  "description": "HTML Sitemap WordPress plugin block.",
