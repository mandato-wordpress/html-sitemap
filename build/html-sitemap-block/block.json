    "html": false
  },
  "textdomain": "html-sitemap",
  "editorScript": "file:./index.js",
  "attributes": {
    "child_of": {
      "type": "string",
      "default": ""
    },
    "authors": {
      "type": "string",
      "default": ""
    },
    "include": {
      "type": "string",
      "default": ""
    },
    "exclude": {
      "type": "string",
      "default": ""
    },
    "depth": {
      "type": "string",
      "default": ""
    },
    "sort_order": {
      "type": "string",
      "default": ""
    },
    "sort_column": {
      "type": "string",
      "default": ""
